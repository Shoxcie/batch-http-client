{
    "name": "shoxcie/batch-http-client",
    "description": "HTTP request batch executor with individual retries, built on Symfony HttpClient.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^7.4",
        "symfony/http-client": "^5.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "pestphp/pest": "^1.23",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "Shoxcie\\BatchHttpClient\\": "src/"
        },
        "files": [
            "src/Response.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Shoxcie\\BatchHttpClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest --color=always",
        "test:coverage": "pest --coverage --min=80",
        "test:type-coverage": "pest --type-coverage --min=100",
        "analyse": "phpstan analyse",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "quality": [
            "@analyse",
            "@rector:check",
            "@cs:check",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
